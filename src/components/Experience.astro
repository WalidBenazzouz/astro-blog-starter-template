---
// Experience & Education Component - Vertical timeline

const experiences = [
  {
    type: "work",
    title: "Stage Développement Applicatif & Data",
    organization: "Crédit du Maroc (CDM)",
    location: "Casablanca",
    period: "Mars - Août 2026",
    description: "Développement d'une application métier full-stack pour traitement automatisé de flux bancaires avec validation et conformité. Projet Data Services & Base Contrat : optimisation SQL, fiabilisation processus de réconciliation de données contractuelles. Amélioration qualité des données opérationnelles avec impact direct sur reportings métier.",
    stack: "Java, Spring Boot, Oracle Database, SQL avancé"
  },
  {
    type: "work",
    title: "Stage Développement IA & Infrastructure",
    organization: "Royal Air Maroc (RAM)",
    location: "Casablanca",
    period: "Jul - Sep 2025",
    description: "Chatbot IA générative pour assistance client avec intégration RAG. Infrastructure d'administration sécurisée (authentification, contrôle accès, logs) et API backend performante.",
    stack: "Python, FastAPI, React, Groq"
  },
  {
    type: "work",
    title: "Stage Cybersécurité & Infrastructure",
    organization: "T-MAN Holding",
    location: "Casablanca",
    period: "Jul 2024",
    description: "Audit sécurité IT complet avec identification vulnérabilités. Déploiement pare-feu et stratégie de sauvegarde automatisée.",
    stack: ""
  }
];

const education = [
  {
    type: "education",
    title: "Master MIAGE IA2 — Intelligence Artificielle Appliquée",
    organization: "Université Côte d'Azur (UCA)",
    location: "Nice, France",
    period: "Oct 2025 - Jul 2026",
    description: "Spécialisation en Intelligence Artificielle Appliquée. En cours.",
    stack: ""
  },
  {
    type: "education",
    title: "Cycle Ingénieur MIAGE",
    organization: "EMSI",
    location: "Casablanca",
    period: "Oct 2025 - Jul 2026",
    description: "Double diplôme en partenariat avec UCA. En cours.",
    stack: ""
  },
  {
    type: "education",
    title: "Classes Préparatoires",
    organization: "EMSI",
    location: "Casablanca",
    period: "Oct 2021 - Jul 2024",
    description: "Cycle préparatoire en informatique et réseaux.",
    stack: ""
  },
  {
    type: "education",
    title: "Baccalauréat Scientifique BIOF",
    organization: "Lycée Yassamine",
    location: "Casablanca",
    period: "2021",
    description: "Option internationale française.",
    stack: ""
  }
];
---

<section class="experience" id="experience">
  <div class="container">
    <div class="experience-grid">
      <!-- Work Experience -->
      <div class="timeline-section">
        <div class="section-label reveal">Experience</div>
        <h2 class="section-heading reveal">Professional</h2>
        
        <div class="timeline">
          {experiences.map((item, index) => (
            <div class={`timeline-item reveal-stagger stagger-${index + 1}`}>
              <div class="timeline-marker">
                <div class="marker-dot"></div>
                <div class="marker-line"></div>
              </div>
              <div class="timeline-content">
                <span class="timeline-period">{item.period}</span>
                <h3 class="timeline-title">{item.title}</h3>
                <div class="timeline-org">
                  <span class="org-name">{item.organization}</span>
                  <span class="org-location">— {item.location}</span>
                </div>
                <p class="timeline-description">{item.description}</p>
                {item.stack && (
                  <div class="timeline-stack">
                    {item.stack.split(", ").map((tech) => (
                      <span class="stack-tag">{tech}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Education -->
      <div class="timeline-section">
        <div class="section-label reveal">Education</div>
        <h2 class="section-heading reveal">Formation</h2>
        
        <div class="timeline">
          {education.map((item, index) => (
            <div class={`timeline-item reveal-stagger stagger-${index + 1}`}>
              <div class="timeline-marker">
                <div class="marker-dot"></div>
                <div class="marker-line"></div>
              </div>
              <div class="timeline-content">
                <span class="timeline-period">{item.period}</span>
                <h3 class="timeline-title">{item.title}</h3>
                <div class="timeline-org">
                  <span class="org-name">{item.organization}</span>
                  <span class="org-location">— {item.location}</span>
                </div>
                <p class="timeline-description">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .experience-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: var(--space-2xl);
  }

  .section-heading {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin-bottom: var(--space-xl);
  }

  .timeline {
    position: relative;
  }

  .timeline-item {
    display: flex;
    gap: var(--space-lg);
    padding-bottom: var(--space-xl);
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-item:last-child .marker-line {
    display: none;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .marker-dot {
    width: 12px;
    height: 12px;
    background: var(--color-bg);
    border: 2px solid var(--color-accent);
    transition: background var(--duration-fast) var(--ease-out-quart);
  }

  .timeline-item:hover .marker-dot {
    background: var(--color-accent);
  }

  .marker-line {
    width: 1px;
    flex: 1;
    background: var(--color-border);
    margin-top: var(--space-sm);
  }

  .timeline-content {
    flex: 1;
    padding-top: -2px;
  }

  .timeline-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .timeline-title {
    font-size: 1.125rem;
    margin-bottom: var(--space-xs);
  }

  .timeline-org {
    margin-bottom: var(--space-sm);
  }

  .org-name {
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .org-location {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .timeline-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .timeline-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
  }

  .stack-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-accent);
    padding: 2px var(--space-sm);
    border: 1px solid var(--color-accent-dim);
    background: var(--color-accent-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .experience-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
